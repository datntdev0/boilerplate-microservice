{
    "files.exclude": {
        "**/.git": true,
        "**/.vs": true,
        "**/bin": true,
        "**/obj": true,
        "**/node_modules": true,
        "**/TestResults": true,
    },
    "[typescript]": {
        "editor.tabSize": 2
    },
    "[javascript]": {
        "editor.tabSize": 2
    },
    "[json]": {
        "editor.tabSize": 2
    },
    "[csharp]": {
        "editor.tabSize": 4
    },
    "[scss]": {
        "editor.tabSize": 4
    },
    "chat.tools.terminal.autoApprove": {
        "npm run test:ci": true,
        "npm run nswag": true,
        "dotnet build": true,
        "dotnet test": true,
        "dotnet run": true,
    },
}
