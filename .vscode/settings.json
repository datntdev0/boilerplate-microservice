{
    "files.exclude": {
        "**/.git": true,
        "**/.vs": true,
        "**/bin": true,
        "**/obj": true,
        "**/node_modules": true,
        "**/TestResults": true,
    },
    "[typescript]": {
        "editor.tabSize": 2
    },
    "[javascript]": {
        "editor.tabSize": 2
    },
    "[json]": {
        "editor.tabSize": 2
    },
    "[csharp]": {
        "editor.tabSize": 4
    },
    "[scss]": {
        "editor.tabSize": 4
    },
    "workbench.browser.enableChatTools": true
}
